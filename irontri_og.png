<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { width: 1200px; height: 630px; overflow: hidden; background: #0d0d0d; }
  canvas { display: block; }
</style>
</head>
<body>
<canvas id="c" width="1200" height="630"></canvas>
<script>
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
const W = 1200, H = 630;

// Background
ctx.fillStyle = '#0d0d0d';
ctx.fillRect(0, 0, W, H);

// Subtle grid lines
ctx.strokeStyle = 'rgba(255,255,255,0.03)';
ctx.lineWidth = 1;
for (let x = 0; x < W; x += 60) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke(); }
for (let y = 0; y < H; y += 60) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke(); }

// Blue glow top left
const grad1 = ctx.createRadialGradient(200, 200, 0, 200, 200, 400);
grad1.addColorStop(0, 'rgba(30,144,255,0.18)');
grad1.addColorStop(1, 'rgba(30,144,255,0)');
ctx.fillStyle = grad1;
ctx.fillRect(0, 0, W, H);

// Blue glow bottom right
const grad2 = ctx.createRadialGradient(1000, 500, 0, 1000, 500, 350);
grad2.addColorStop(0, 'rgba(30,144,255,0.1)');
grad2.addColorStop(1, 'rgba(30,144,255,0)');
ctx.fillStyle = grad2;
ctx.fillRect(0, 0, W, H);

// Blue accent bar top
ctx.fillStyle = '#1E90FF';
ctx.fillRect(0, 0, W, 6);

// Left side content area
// Logo
ctx.font = 'bold 72px Arial, sans-serif';
ctx.fillStyle = '#ffffff';
ctx.letterSpacing = '-2px';
ctx.fillText('irontri', 80, 160);

// Blue underline accent
ctx.fillStyle = '#1E90FF';
ctx.fillRect(80, 172, 180, 4);

// Tagline
ctx.font = '28px Arial, sans-serif';
ctx.fillStyle = 'rgba(255,255,255,0.6)';
ctx.fillText('Personalised Triathlon Training', 80, 230);

// Main headline
ctx.font = 'bold 52px Arial, sans-serif';
ctx.fillStyle = '#ffffff';
ctx.fillText('Your race. Your plan.', 80, 320);
ctx.fillText('No guesswork.', 80, 385);

// Features row
const features = ['🏊 Swim', '🚴 Bike', '🏃 Run'];
let fx = 80;
features.forEach(f => {
  ctx.font = '20px Arial, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.5)';
  ctx.fillText(f, fx, 455);
  fx += 140;
});

// Strava badge
ctx.fillStyle = 'rgba(252,76,2,0.15)';
roundRect(ctx, 80, 480, 200, 44, 10);
ctx.fill();
ctx.strokeStyle = 'rgba(252,76,2,0.4)';
ctx.lineWidth = 1;
ctx.stroke();
ctx.font = 'bold 16px Arial, sans-serif';
ctx.fillStyle = 'rgba(252,76,2,0.9)';
ctx.fillText('⚡ Strava auto-sync', 100, 508);

// Right side — plan card mockup
const cardX = 680, cardY = 80, cardW = 460, cardH = 470;

// Card background
ctx.fillStyle = 'rgba(255,255,255,0.04)';
roundRect(ctx, cardX, cardY, cardW, cardH, 20);
ctx.fill();
ctx.strokeStyle = 'rgba(255,255,255,0.1)';
ctx.lineWidth = 1;
ctx.stroke();

// Card header
ctx.fillStyle = '#1E90FF';
roundRectTop(ctx, cardX, cardY, cardW, 56, 20);
ctx.fill();

ctx.font = 'bold 16px Arial, sans-serif';
ctx.fillStyle = '#fff';
ctx.fillText('Week 3 — Build Phase', cardX + 24, cardY + 36);

ctx.font = '13px Arial, sans-serif';
ctx.fillStyle = 'rgba(255,255,255,0.7)';
ctx.fillText('8h 25m total', cardX + 340, cardY + 36);

// Day pills
const days = [
  { d: 'MON', type: 'swim', color: '#38bdf8' },
  { d: 'TUE', type: 'bike', color: '#fb923c' },
  { d: 'WED', type: 'rest', color: '#666' },
  { d: 'THU', type: 'run', color: '#4ade80' },
  { d: 'FRI', type: 'brick', color: '#a78bfa' },
  { d: 'SAT', type: 'swim', color: '#38bdf8' },
  { d: 'SUN', type: 'bike', color: '#fb923c' },
];
days.forEach((day, i) => {
  const dx = cardX + 20 + i * 60, dy = cardY + 80;
  ctx.fillStyle = day.type === 'rest' ? 'rgba(255,255,255,0.04)' : `${day.color}22`;
  roundRect(ctx, dx, dy, 50, 60, 8);
  ctx.fill();
  ctx.strokeStyle = day.type === 'rest' ? 'rgba(255,255,255,0.08)' : `${day.color}55`;
  ctx.lineWidth = 1;
  ctx.stroke();
  ctx.font = 'bold 10px Arial, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.textAlign = 'center';
  ctx.fillText(day.d, dx + 25, dy + 16);
  if (day.type !== 'rest') {
    ctx.fillStyle = day.color;
    ctx.font = 'bold 20px Arial, sans-serif';
    ctx.fillText('✓', dx + 25, dy + 44);
  }
  ctx.textAlign = 'left';
});

// Session card
const sY = cardY + 170;
ctx.fillStyle = 'rgba(255,255,255,0.04)';
roundRect(ctx, cardX + 20, sY, cardW - 40, 110, 12);
ctx.fill();
ctx.strokeStyle = '#38bdf8';
ctx.lineWidth = 2;
ctx.beginPath();
ctx.moveTo(cardX + 20, sY + 12);
ctx.lineTo(cardX + 20, sY + 98);
ctx.stroke();

ctx.font = 'bold 16px Arial, sans-serif';
ctx.fillStyle = '#fff';
ctx.fillText('Threshold Intervals', cardX + 36, sY + 30);

ctx.font = '13px Arial, sans-serif';
ctx.fillStyle = 'rgba(255,255,255,0.45)';
ctx.fillText('Saturday · 70 min · Zone 4', cardX + 36, sY + 52);

ctx.font = '12px Arial, sans-serif';
ctx.fillStyle = 'rgba(255,255,255,0.6)';
ctx.fillText('8×100m at RPE 8 · 15 sec rest · Focus on hip rotation and early catch', cardX + 36, sY + 78);

ctx.font = '12px Arial, sans-serif';
ctx.fillStyle = '#38bdf8';
ctx.fillText('1:45/100m', cardX + 36, sY + 98);

// Coach note
const cnY = sY + 130;
ctx.fillStyle = 'rgba(30,144,255,0.06)';
roundRect(ctx, cardX + 20, cnY, cardW - 40, 80, 12);
ctx.fill();
ctx.strokeStyle = 'rgba(30,144,255,0.2)';
ctx.lineWidth = 1;
ctx.stroke();

ctx.font = 'italic 13px Arial, sans-serif';
ctx.fillStyle = 'rgba(255,255,255,0.5)';
wrapText(ctx, '"Good effort on those 8×100s — holding 1:48 average in week 3 tells me your threshold is responding well. Keep that hip rotation cue."', cardX + 36, cnY + 24, cardW - 72, 18);

// URL badge bottom
ctx.fillStyle = 'rgba(30,144,255,0.12)';
roundRect(ctx, 80, 560, 280, 40, 10);
ctx.fill();
ctx.strokeStyle = 'rgba(30,144,255,0.3)';
ctx.lineWidth = 1;
ctx.stroke();
ctx.font = 'bold 15px Arial, sans-serif';
ctx.fillStyle = '#1E90FF';
ctx.fillText('irontriapp.com', 100, 586);

function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.arcTo(x + w, y, x + w, y + r, r);
  ctx.lineTo(x + w, y + h - r);
  ctx.arcTo(x + w, y + h, x + w - r, y + h, r);
  ctx.lineTo(x + r, y + h);
  ctx.arcTo(x, y + h, x, y + h - r, r);
  ctx.lineTo(x, y + r);
  ctx.arcTo(x, y, x + r, y, r);
  ctx.closePath();
}

function roundRectTop(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.arcTo(x + w, y, x + w, y + r, r);
  ctx.lineTo(x + w, y + h);
  ctx.lineTo(x, y + h);
  ctx.lineTo(x, y + r);
  ctx.arcTo(x, y, x + r, y, r);
  ctx.closePath();
}

function wrapText(ctx, text, x, y, maxW, lineH) {
  const words = text.split(' ');
  let line = '';
  for (let i = 0; i < words.length; i++) {
    const test = line + words[i] + ' ';
    if (ctx.measureText(test).width > maxW && i > 0) {
      ctx.fillText(line, x, y);
      line = words[i] + ' ';
      y += lineH;
    } else { line = test; }
  }
  ctx.fillText(line, x, y);
}

// Export as PNG
setTimeout(() => {
  const link = document.createElement('a');
  link.download = 'irontri_og.png';
  link.href = canvas.toDataURL('image/png');
  link.click();
}, 500);
</script>
</body>
</html>
